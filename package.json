{
  "name": "afaktury-sprzedaz",
  "version": "0.1.0",
  "private": true,
  "description": "Dashboard sprzedazy pozycji (kod produktu x miesiac) na podstawie faktur z afaktury.pl",
  "scripts": {
    "dev": "tsx watch src/server/server.ts",
    "start": "node dist/server/server.js",
    "build": "tsc -p tsconfig.json",
    "sync": "tsx src/sync/cli.ts",
    "seed": "tsx src/sync/cli.ts --mock",
    "build:demo": "tsx scripts/build-demo.ts",
    "test": "tsx --test test/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
