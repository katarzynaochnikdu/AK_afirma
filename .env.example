# Skopiuj do .env i uzupelnij wartosciami z afaktury.pl (Ustawienia -> Klucz API, plan Prestige).
# Plik .env jest w .gitignore i NIE moze trafic do repo.

# Autoryzacja API afaktury.pl (para id + klucz)
AFAKTURY_ID=
AFAKTURY_KEY=

# Alternatywnie pojedynczy token (jesli uzywasz tokenu zamiast pary powyzej)
# AFAKTURY_TOKEN=

# Bazowy URL API (zwykle bez zmian)
AFAKTURY_BASE_URL=https://afaktury.pl/api

# Ktore pole katalogu Product jest kanonicznym kodem pozycji:
#   ean          -> EAN-13 / ISBN (domyslne dla wydawnictwa)
#   productNumber -> wewnetrzny numer produktu / SKU
PRODUCT_CODE_FIELD=ean

# Port dashboardu
PORT=3000

# Sciezka do lokalnej bazy (cache)
DB_PATH=data/sprzedaz.sqlite
